{
  "name": "@authwrite/observer-pg",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Postgres audit log and policy store observer for AuthEngine.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardadalton/authwrite.git",
    "directory": "packages/observer-pg"
  },
  "keywords": ["authorization", "authz", "observer", "audit", "postgres"],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "test -d dist && echo 'dist already built, skipping' || (npm run clean && npm run build)"
  },
  "dependencies": {
    "@authwrite/core": "*"
  },
  "peerDependencies": {
    "pg": ">=8.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.0.0",
    "pg": "^8.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
